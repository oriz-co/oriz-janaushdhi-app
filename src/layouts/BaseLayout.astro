---
/*
 * BaseLayout — Janaushdhi v0.
 * Locked design: bone-white bg, medical-green accent, IBM Plex Sans single family.
 * NO ADS. Public-health surface. All 4 nav surfaces: Header, Footer, Sidebar, BottomBar.
 */
import '~/styles/tokens.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  showSidebar?: boolean
  activeFacet?: string
}

const {
  title = 'Janaushdhi — affordable generic medicines for India',
  description = 'Free price intelligence for Pradhan Mantri Jan Aushadhi medicines. Find generic prices, compare savings, locate stores. No ads.',
  canonical = `https://janaushdhi.oriz.in${Astro.url.pathname}`,
  noindex = false,
  showSidebar = false,
  activeFacet = '',
} = Astro.props

const path = Astro.url.pathname

const navLinks = [
  { href: '/browse/', label: 'Browse' },
  { href: '/#search', label: 'Search' },
  { href: '/about/', label: 'About' },
  { href: '/savings/', label: 'Save' },
]

const bottomLinks = [
  { href: '/', icon: '⌂', label: 'Home' },
  { href: '/browse/', icon: '☰', label: 'Browse' },
  { href: '/#search', icon: '⌕', label: 'Search' },
  { href: '/savings/', icon: '₹', label: 'Save' },
  { href: '/about/', icon: 'ℹ', label: 'About' },
]

const facets = {
  categories: [
    { slug: '', label: 'All categories' },
    { slug: 'analgesic', label: 'Analgesic / Pain' },
    { slug: 'antibiotic', label: 'Antibiotic' },
    { slug: 'cardiovascular', label: 'Cardiovascular' },
    { slug: 'diabetes', label: 'Diabetes' },
    { slug: 'cns', label: 'Central Nervous System' },
    { slug: 'gastro', label: 'Gastrointestinal' },
    { slug: 'derma', label: 'Dermatology / Topical' },
    { slug: 'vitamins', label: 'Vitamins & Minerals' },
  ],
  units: [
    { slug: '', label: 'Any unit' },
    { slug: 'tablets', label: 'Tablets' },
    { slug: 'capsules', label: 'Capsules' },
    { slug: 'syrup', label: 'Syrup / Suspension' },
    { slug: 'injection', label: 'Injection' },
    { slug: 'topical', label: 'Cream / Gel / Ointment' },
  ],
  price: [
    { slug: '', label: 'Any price' },
    { slug: 'lt-10', label: 'Under ₹10' },
    { slug: '10-30', label: '₹10 — ₹30' },
    { slug: '30-100', label: '₹30 — ₹100' },
    { slug: 'gt-100', label: 'Above ₹100' },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="janaushdhi · oriz" />
    <meta name="theme-color" content="#0F766E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    {/* ── HEADER ───────────────────────────────────────────── */}
    <header class="site-header" role="banner">
      <div class="site-header-inner">
        <a class="brand" href="/" aria-label="Janaushdhi home">
          <span class="brand-mark" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="18" height="18" rx="4" fill="#0F766E" />
              <path d="M12 7v10M7 12h10" stroke="#fff" stroke-width="2.5" stroke-linecap="round" />
            </svg>
          </span>
          <span class="brand-text">
            <span class="brand-family">oriz</span>
            <span class="brand-slash">/</span>
            <span class="brand-app">janaushdhi</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navLinks.map((l) => (
            <a href={l.href} class={path === l.href ? 'active' : ''}>{l.label}</a>
          ))}
        </nav>
      </div>
    </header>

    {/* ── MAIN + optional SIDEBAR ──────────────────────────── */}
    {showSidebar ? (
      <div class="page">
        <div class="layout-with-aside">
          <aside class="aside-facets" aria-label="Filters">
            <p class="facet-h">Therapeutic category</p>
            <ul class="facet-list">
              {facets.categories.map((f) => (
                <li><a href={f.slug ? `/browse/?cat=${f.slug}` : '/browse/'} class={activeFacet === f.slug ? 'active' : ''}>{f.label}</a></li>
              ))}
            </ul>
            <p class="facet-h">Unit type</p>
            <ul class="facet-list">
              {facets.units.map((f) => (
                <li><a href={f.slug ? `/browse/?unit=${f.slug}` : '/browse/'}>{f.label}</a></li>
              ))}
            </ul>
            <p class="facet-h">Price range</p>
            <ul class="facet-list">
              {facets.price.map((f) => (
                <li><a href={f.slug ? `/browse/?price=${f.slug}` : '/browse/'}>{f.label}</a></li>
              ))}
            </ul>
          </aside>
          <main id="main"><slot /></main>
        </div>
      </div>
    ) : (
      <main id="main"><slot /></main>
    )}

    {/* ── FOOTER ───────────────────────────────────────────── */}
    <footer class="site-footer" role="contentinfo">
      <div class="footer-accent" aria-hidden="true"></div>
      <div class="footer-inner">
        <div class="footer-col">
          <p class="footer-h">Browse</p>
          <ul>
            <li><a href="/browse/">All medicines</a></li>
            <li><a href="/savings/">Savings calculator</a></li>
            <li><a href="/stores/">Find a Kendra</a></li>
            <li><a href="/find-substitute/">Find substitute</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-h">Resources</p>
          <ul>
            <li><a href="https://www.janaushadhi.gov.in/" rel="noopener noreferrer external">janaushadhi.gov.in</a></li>
            <li><a href="https://pmbjp.gov.in/" rel="noopener noreferrer external">PMBJP scheme</a></li>
            <li><a href="https://www.india.gov.in/" rel="noopener noreferrer external">india.gov.in</a></li>
            <li><a href="https://oriz.in/">Oriz family</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-h">Legal</p>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/privacy/">Privacy</a></li>
            <li><a href="/terms/">Terms</a></li>
            <li><a href="/disclaimer/">Disclaimer</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/refunds/">Refunds</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-fineprint">
        <p>
          <strong>No ads. No tracking.</strong> Janaushdhi is a public-health price-intelligence surface.
          Prices scraped from janaushadhi.gov.in and may lag the official source by up to 24 hours.
          Talk to a registered pharmacist or doctor before substituting any medication.
        </p>
        <p class="mono">© 2026 oriz · MIT licensed · <a href="https://github.com/chirag127/oriz-janaushdhi-app">source on github</a></p>
      </div>
    </footer>

    {/* ── BOTTOM BAR (mobile) ──────────────────────────────── */}
    <nav class="bottombar" aria-label="Mobile primary">
      {bottomLinks.map((l) => (
        <a href={l.href} class={path === l.href ? 'active' : ''}>
          <span class="bb-icon" aria-hidden="true">{l.icon}</span>
          <span class="bb-label">{l.label}</span>
        </a>
      ))}
    </nav>

    <style is:inline>
      /* ── Header ── */
      .site-header {
        position: sticky; top: 0; z-index: 50;
        background: rgba(250, 250, 249, 0.92);
        backdrop-filter: saturate(180%) blur(10px);
        -webkit-backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--color-border);
      }
      .site-header-inner {
        max-width: 1180px; margin: 0 auto;
        padding: 14px 16px;
        display: flex; align-items: center; justify-content: space-between; gap: 16px;
      }
      .brand { display: inline-flex; align-items: center; gap: 10px; color: var(--color-fg); }
      .brand:hover { text-decoration: none; }
      .brand-mark { display: inline-flex; }
      .brand-text { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; letter-spacing: -0.01em; }
      .brand-family { color: var(--color-fg); }
      .brand-slash { color: var(--color-muted); margin: 0 4px; font-weight: 400; }
      .brand-app { color: var(--color-accent); }
      .site-nav { display: flex; gap: 4px; flex-wrap: wrap; }
      .site-nav a {
        padding: 8px 12px; border-radius: 6px;
        color: var(--color-fg); font-weight: 500; font-size: 0.95rem;
      }
      .site-nav a:hover { background: var(--color-bg-alt); text-decoration: none; }
      .site-nav a.active { color: var(--color-accent); }
      @media (max-width: 540px) { .site-nav a { padding: 6px 8px; font-size: 0.85rem; } .brand-slash, .brand-family { display: none; } }

      /* ── Footer ── */
      .site-footer { margin-top: 80px; background: var(--color-bg-alt); border-top: 1px solid var(--color-border); position: relative; }
      .footer-accent { height: 3px; background: var(--color-accent); }
      .footer-inner {
        max-width: 1180px; margin: 0 auto;
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
        padding: 48px 16px 32px;
      }
      @media (max-width: 720px) { .footer-inner { grid-template-columns: 1fr 1fr; gap: 24px; } }
      @media (max-width: 460px) { .footer-inner { grid-template-columns: 1fr; } }
      .footer-h {
        font: 500 0.72rem/1 var(--font-utility);
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--color-muted); margin: 0 0 16px;
      }
      .footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
      .footer-col a { color: var(--color-fg); font-size: 0.93rem; }
      .footer-fineprint {
        max-width: 1180px; margin: 0 auto;
        padding: 24px 16px 96px;
        border-top: 1px solid var(--color-border);
        color: var(--color-muted); font-size: 0.86rem;
      }
      .footer-fineprint p { margin: 0 0 8px; }
      .footer-fineprint .mono { font-family: var(--font-utility); font-size: 0.78rem; }

      /* ── BottomBar (mobile only) ── */
      .bottombar {
        display: none;
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 60;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(8px);
        border-top: 1px solid var(--color-border);
        padding: 6px 4px calc(6px + env(safe-area-inset-bottom)) 4px;
        justify-content: space-around;
      }
      .bottombar a {
        flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
        padding: 6px 2px; color: var(--color-muted); text-decoration: none;
        font-size: 0.7rem; border-radius: 6px;
      }
      .bottombar a.active { color: var(--color-accent); }
      .bb-icon { font-size: 1.2rem; line-height: 1; }
      .bb-label { font-family: var(--font-utility); font-weight: 500; letter-spacing: 0.04em; }
      @media (max-width: 720px) {
        .bottombar { display: flex; }
        body { padding-bottom: 64px; }
      }
    </style>
  </body>
</html>
